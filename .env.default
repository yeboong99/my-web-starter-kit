# 이 파일을 복사하여 .env 파일을 생성하세요.
# cp .env.default .env

# PostgreSQL 설정
DB_HOST=localhost
DB_PORT=5433          # 로컬 PostgreSQL 충돌 방지용 (기본 5432 대신 5433 사용)
DB_NAME=demo           # 데이터베이스 이름
DB_USER=demo           # 데이터베이스 사용자
DB_PASSWORD=           # 안전한 비밀번호로 변경하세요

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
